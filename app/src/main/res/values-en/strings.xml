    <!-- FAQ / Feedback -->
    <string name="faq_title">FAQ</string>
    <string name="faq_q1">Does the app delete my files?</string>
    <string name="faq_a1">No. It only deletes files you explicitly confirm. You always see a confirmation dialog before deletion.</string>
    <string name="faq_q2">Why is there no RAM \"boost\" button?</string>
    <string name="faq_a2">Android 8+ manages memory automatically. Third-party apps cannot kill other processes; \"boost\" buttons are cosmetic.</string>
    <string name="faq_q3">Is my data sent to a server?</string>
    <string name="faq_a3">No. All scanning and analysis runs on-device. No file or statistic is sent over the network.</string>
